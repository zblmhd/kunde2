# ─────────────────────────────────────────────────────────────────────────
# Kunde TCM — environment variables
# Copy to `.env.local` for local dev; configure all in Vercel project settings
# for production.
# ─────────────────────────────────────────────────────────────────────────

# Site — used by metadataBase, sitemap.ts, robots.ts, JSON-LD canonical URLs.
# Production: https://kundetcm.com  (recommended primary domain)
NEXT_PUBLIC_SITE_URL=https://kundetcm.com

# ─── Admin (Step 5 CMS) ──────────────────────────────────────────────────
# Login password for /admin. Use a strong random string in production.
ADMIN_PASSWORD=change-me-in-production
# HMAC secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production

# ─── Database (Step 5) ───────────────────────────────────────────────────
# Optional: Postgres / Vercel Postgres connection string.
# Leave blank to fall back to file-system JSON storage under /data.
DATABASE_URL=

# ─── Analytics (Step 6) ──────────────────────────────────────────────────
# GA4 measurement ID, e.g. G-XXXXXXXXXX. If unset, no analytics script is
# emitted (safe for dev / preview).
NEXT_PUBLIC_GA_ID=

# Google Search Console site-verification token (the `content=` value of
# the `<meta name="google-site-verification">` tag GSC gives you). If
# unset, no verification meta tag is rendered.
NEXT_PUBLIC_GSC_VERIFICATION=
