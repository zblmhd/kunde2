# ─────────────────────────────────────────────────────────────────────────
# Kunde TCM — environment variables
# Copy to `.env.local` for local dev; configure all in Vercel project settings.
# ─────────────────────────────────────────────────────────────────────────

# Site — used by metadataBase, sitemap.ts, robots.ts, JSON-LD canonical URLs.
NEXT_PUBLIC_SITE_URL=https://kundetcm.com

# ─── Admin (CMS login) ───────────────────────────────────────────────────
# Login password for /admin. Use a strong random string in production.
ADMIN_PASSWORD=change-me-in-production
# HMAC secret used to sign admin session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production

# ─── Supabase ────────────────────────────────────────────────────────────
# Project URL — visible in Supabase Dashboard → Settings → API
# e.g. https://qdatsbsgcmkmijfsjhjt.supabase.co
SUPABASE_URL=

# Service-role key — Supabase Dashboard → Settings → API → service_role
# KEEP THIS SECRET — never expose in the browser / NEXT_PUBLIC_ vars
SUPABASE_SERVICE_ROLE_KEY=

# Anon (public) key — used only if you add client-side Supabase calls
# Safe to expose; RLS policies deny all public access to CMS tables.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Analytics ───────────────────────────────────────────────────────────
# GA4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# Google Search Console site-verification token.
NEXT_PUBLIC_GSC_VERIFICATION=
